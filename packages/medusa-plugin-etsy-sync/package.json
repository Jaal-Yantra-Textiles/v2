{
  "name": "@jytextiles/medusa-plugin-etsy-sync",
  "version": "0.1.4",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "Medusa v2 plugin to sync Medusa products to a personal Etsy shop account via the Etsy Open API v3.",
  "keywords": [
    "medusa-v2",
    "medusa-plugin-integration",
    "medusa-plugin-other",
    "etsy",
    "medusa",
    "plugin"
  ],
  "license": "MIT",
  "author": "Jaal Yantra Textiles",
  "homepage": "https://github.com/Jaal-Yantra-Textiles/v2/tree/main/packages/medusa-plugin-etsy-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaal-Yantra-Textiles/v2.git",
    "directory": "packages/medusa-plugin-etsy-sync"
  },
  "bugs": {
    "url": "https://github.com/Jaal-Yantra-Textiles/v2/issues"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "db:generate": "medusa plugin:db:generate",
    "test": "jest"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "files": [
    "src",
    ".medusa"
  ],
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
