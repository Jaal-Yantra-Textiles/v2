**/node_modules
**/.medusa
**/.cache
**/.turbo
**/dist
**/build
**/.next
**/.vercel

# Test and coverage output
**/coverage
**/.nyc_output
apps/backend/integration-tests/temp
apps/backend/integration-tests/__fixtures__/logs

# Editor / OS
.vscode
.idea
**/.DS_Store

# Env files — never bake secrets into images
**/.env
**/.env.*
!**/.env.railway.*.sample
!**/.env.template

# Git / CI
.git
.github
.changeset
.husky

# Large reference dirs not needed for backend build
apps/docs
apps/storefront
apps/storefront-mobile
apps/storefront-starter
apps/media-gallery
apps/partner-ui/node_modules
apps/backend/uploads
apps/backend/static/uploads
apps/backend/specs

# Logs / misc
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Generated artifacts that should be rebuilt inside the image
apps/backend/.medusa
apps/backend/workflow-schemas.json
apps/backend/tsconfig.resolved.json
