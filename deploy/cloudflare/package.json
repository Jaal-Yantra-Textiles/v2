{
  "name": "@jyt/cloudflare-deploy",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Workers + Containers deployment for the JYT Medusa backend.",
  "scripts": {
    "deploy": "wrangler deploy --config ../../wrangler.toml",
    "tail": "wrangler tail --config ../../wrangler.toml",
    "dev": "wrangler dev --config ../../wrangler.toml",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.1.0",
    "@cloudflare/workers-types": "^4.20260501.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.91.0"
  }
}
