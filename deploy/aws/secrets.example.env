# Template for AWS Secrets Manager + SSM seeding.
#
# Usage:
#   1. Copy to secrets.local.env (gitignored by deploy/aws/.gitignore).
#   2. Fill in real values:
#      - DB, Redis, JWT, cookie, CORS, MEDUSA_BACKEND_URL → from Railway dashboard
#      - S3_* → from your new R2 bucket + API token
#      - SENTRY_DSN → from your new Sentry project
#      - Payment/email/shipping integrations → from the respective dashboards
#        (only fill in the ones currently live in Railway prod)
#   3. Run: bash deploy/aws/scripts/seed-secrets.sh prod
#
# Never commit secrets.local.env. It's in .gitignore.

# === Rotating secrets (→ AWS Secrets Manager) ===

DATABASE_URL=
REDIS_URL=
JWT_SECRET=
COOKIE_SECRET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional integrations — uncomment + fill if live in production
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYU_MERCHANT_KEY=
# PAYU_MERCHANT_SALT=
# RESEND_API_KEY=
# MAILJET_API_KEY=
# MAILJET_SECRET_KEY=
# MAILEROO_API_KEY=
# DHL_API_KEY=
# DHL_API_SECRET=
# FEDEX_CLIENT_ID=
# FEDEX_CLIENT_SECRET=
# UPS_CLIENT_ID=
# UPS_CLIENT_SECRET=
# AUSPOST_CLIENT_ID=
# AUSPOST_CLIENT_SECRET=
# DELHIVERY_API_TOKEN=

# === Non-rotating config (→ SSM Parameter Store, free) ===

STORE_CORS=
ADMIN_CORS=
AUTH_CORS=
MEDUSA_BACKEND_URL=https://v3.jaalyantra.com
S3_BUCKET=
S3_ENDPOINT=
S3_FILE_URL=
SENTRY_DSN=

# Optional integration config (paired with the secrets above)
# RESEND_FROM_EMAIL=
# MAILJET_FROM_EMAIL=
# MAILJET_FROM_NAME=
# MAILEROO_FROM_EMAIL=
# MAILEROO_FROM_NAME=
# DHL_ACCOUNT_NUMBER=
# DHL_SANDBOX=
# FEDEX_ACCOUNT_NUMBER=
# FEDEX_SANDBOX=
# UPS_ACCOUNT_NUMBER=
# UPS_SANDBOX=
# AUSPOST_ACCOUNT_NUMBER=
# AUSPOST_SANDBOX=
# DELHIVERY_SANDBOX=
# PAYU_MODE=
